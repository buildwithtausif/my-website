---
import "../styles/global.css"
import Layout from "../layouts/Layout.astro"
import Codebox from "@components/codebox.astro"
---
<Layout title="Tausif Alam | Full Stack Developer">
	<div class="about-me max-w-2xl md:w-145 my-5 mx-auto px-4 sm:px-6 md:px-0 text-white" slot="brief">
		<h1 class="text-xl sm:text-2xl font-mono font-extrabold">Tausif Alam aka <i class="text-lime-400">@buildwithtausif</i></h1>
		<p class="font-mono first-letter:text-5xl sm:first-letter:text-7xl first-letter:font-bold first-letter:text-lime-400 first-letter:capitalize first-letter:mr-3 first-letter:float-left first-letter:leading-none">
			developing scalable systems for every business needs, I'm a full stack developer specializing in Node.js and Golang (Go Programming language) and related frameworks. 
			<br/><br/>
			currently pursuing my <u>bachelor's in computer application</u> from Guru Gobind Singh Indraprastha University, Delhi, India. 
		</p>
	</div>
	<!-- glance-terminal-for-skills -->
	<Codebox slot={"glance-for-skills"}>
	<pre class="font-mono font-bold leading-none
            bg-linear-to-r from-red-400 via-lime-500 to-emerald-400 
            bg-clip-text text-transparent select-none">
   ___ _                      
  / _ \ | __ _ _ __   ___ ___ 
 / /_\/ |/ _` | '_ \ / __/ _ \
/ /_\\| | (_| | | | | (_|  __/
\____/|_|\__,_|_| |_|\___\___|
        </pre>
		<br/>
		<p class="text-red-400">
		[S] Skills<br/>
		----------<br/>
		<span>Languages</span>: C, Javascript, Typescript, Golang <br/>
		<span>Frontend</span>: ReactJS, Astro, HTML, CSS, SASS <br/> 
		<span>Backend & Runtime</span>: Node.js, Express <br/>
		<span>Database</span>: Postgresql, MySQL <br/>
		<span>devTools</span>: Git, Github, Postman, Bruno
		</p>
	</Codebox>
</Layout>
<style>
	/* glance-span-tags */
	span {
		color: var(--color-blue-400);
	}
</style>
