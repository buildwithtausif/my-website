---
import type { GetStaticPaths } from "astro";
import "@styles/global.css";
import PostLayout from "@layouts/postLayout.astro";
import { getCollection, render } from "astro:content";
import createSlug from "@utils/createSlug";

export async function getStaticPaths() {
  const projects = await getCollection("project");
  return projects.map((project) => ({
    params: { slug: createSlug(project.id) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<PostLayout
  title={`${project.data.title} - Project | buildwithtausif`}
  desc={project.data.description}
  keywords={project.data.tags.join(", ")}
>
  <div
    class="max-w-310 px-4 mx-auto sm:px-6 lg:px-8 mt-12 mb-24 font-sans text-neutral-100"
  >
    <div class="mb-4">
      <a
        href="/projects"
        class="text-zinc-500 hover:text-lime-400 uppercase text-xs tracking-wider transition-colors font-bold"
        >&larr; Back to Projects</a
      >
    </div>

    <div
      class="bg-zinc-900/50 border border-zinc-800 p-8 md:p-12 rounded-2xl relative overflow-hidden mb-12"
    >
      <!-- Glow effect -->
      <div
        class="absolute -right-20 -top-20 w-64 h-64 bg-lime-400/10 blur-3xl rounded-full pointer-events-none"
      >
      </div>

      <div
        class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6"
      >
        <div>
          <div class="flex flex-wrap items-center gap-3 mb-4">
            {
              project.data.tags.map((tag: string) => (
                <span class="inline-flex items-center bg-zinc-800/80 px-2.5 py-1 text-[11px] font-bold text-lime-400 uppercase tracking-widest border border-zinc-700">
                  {tag}
                </span>
              ))
            }
          </div>
          <h1
            class="text-4xl md:text-6xl text-neutral-100 font-extrabold capitalize mb-4 tracking-tight"
          >
            {project.data.title}
          </h1>
          <p
            class="text-lg md:text-xl text-neutral-400 max-w-2xl leading-relaxed"
          >
            {project.data.description}
          </p>
        </div>

        <div
          class="flex flex-row md:flex-col gap-4 mt-6 md:mt-0 items-start md:items-end shrink-0"
        >
          {
            project.data.github && (
              <a
                href={project.data.github}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 bg-[#f0f6fc] text-[#1f2328] hover:bg-[#d0d7de] font-semibold px-4 py-2 rounded-md transition-colors text-sm"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                    <path d="M9 18c-4.51 2-5-2-7-2" />
                  </>
                </svg>{" "}
                View Source
              </a>
            )
          }
          <div class="flex flex-col gap-2 text-sm text-neutral-400 font-mono">
            {
              project.data.version && (
                <div class="flex items-center gap-2 justify-start md:justify-end">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="m7.5 4.27 9 5.15" />
                      <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
                      <path d="m3.3 7 8.7 5 8.7-5" />
                      <path d="M12 22V12" />
                    </>
                  </svg>{" "}
                  Release v{project.data.version}
                </div>
              )
            }
            <div class="flex items-center gap-2 justify-start md:justify-end">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M8 2v4"></path><path d="M16 2v4"></path><rect
                  width="18"
                  height="18"
                  x="3"
                  y="4"
                  rx="2"></rect><path d="M3 10h18"></path></svg
              >
              {
                project.data.pubDate.toLocaleDateString("en-US", {
                  month: "long",
                  year: "numeric",
                })
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="rendered-content-wrapper flex flex-col relative items-start my-2.5 mx-auto max-w-4xl"
    >
      <div
        class="content w-full prose prose-invert lg:prose-xl prose-a:text-lime-400 prose-a:no-underline hover:prose-a:underline prose-headings:text-neutral-100 prose-code:text-lime-300"
      >
        <Content />
      </div>
    </div>
  </div>
</PostLayout>
