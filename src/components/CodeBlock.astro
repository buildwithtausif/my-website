---
import hljs from 'highlight.js';
import 'highlight.js/styles/tokyo-night-dark.css';

interface Props {
  code?: string;
  lang?: string;
}

let codeToHighlight = Astro.props.code || '';
const explicitLang = Astro.props.lang;

// If no code prop is provided, we can extract it from the default slot.
// This allows you to use standard Markdown code fences inside the component without template literals!
if (!codeToHighlight && Astro.slots.has('default')) {
  const slotHtml = await Astro.slots.render('default');
  
  // MDX renders standard code fences to `<pre><code>...</code></pre>`.
  // We strip out the HTML tags generated by MDX/Shiki to get the raw string.
  let text = slotHtml.replace(/<[^>]*>/g, '');
  
  // Unescape common HTML entities
  text = text
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&#x27;/g, "'");
    
  // Trim excessive newlines added by MDX wrappers
  codeToHighlight = text.trim();
}

let highlightedCode = '';
let language = 'text';

if (codeToHighlight) {
  if (explicitLang && hljs.getLanguage(explicitLang)) {
    const highlightedResult = hljs.highlight(codeToHighlight, { language: explicitLang });
    highlightedCode = highlightedResult.value;
    language = highlightedResult.language || explicitLang;
  } else {
    const highlightedResult = hljs.highlightAuto(codeToHighlight);
    highlightedCode = highlightedResult.value;
    language = highlightedResult.language || 'text';
  }
}
---

<div class="code-block not-prose my-8 rounded-xl overflow-hidden bg-[#1a1b26] border border-[#292e42] shadow-2xl relative group">
  <!-- Header with window controls and language tag -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-[#292e42] bg-[#16161e]">
    <div class="flex items-center gap-4">
      <!-- MacOS style window buttons -->
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full bg-[#f7768e] shadow-sm"></div>
        <div class="w-3 h-3 rounded-full bg-[#e0af68] shadow-sm"></div>
        <div class="w-3 h-3 rounded-full bg-[#9ece6a] shadow-sm"></div>
      </div>
      <!-- Language badge -->
      <span class="text-[0.65rem] uppercase tracking-wider text-[#7aa2f7] font-semibold bg-[#292e42]/50 px-2 py-0.5 rounded-md mix-blend-screen">
        {language}
      </span>
    </div>
    
    <!-- Copy button -->
    <button 
      class="copy-button text-[#565f89] hover:text-[#c0caf5] transition-all duration-200 flex items-center justify-center p-1.5 rounded-md hover:bg-[#292e42] focus:outline-none" 
      aria-label="Copy code to clipboard"
      title="Copy Code"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy transition-transform active:scale-95"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check hidden text-[#9ece6a]"><path d="M20 6 9 17l-5-5"/></svg>
    </button>
  </div>
  
  <!-- Code block area -->
  <div class="relative bg-[#1a1b26] p-4 sm:p-5 overflow-x-auto custom-scrollbar">
    <pre class="font-mono text-sm leading-relaxed m-0"><code set:html={highlightedCode} class="text-[#c0caf5] hljs" /></pre>
  </div>
</div>

<script>
  // Setup copy functionality for all code blocks
  document.addEventListener('DOMContentLoaded', () => {
    const copyButtons = document.querySelectorAll('.copy-button');
    
    copyButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const container = button.closest('.code-block');
        if (!container) return;
        
        const codeElement = container.querySelector('code');
        const textToCopy = codeElement?.textContent || '';
        
        try {
          await navigator.clipboard.writeText(textToCopy);
          
          // Toggle icons for success state feedback
          const copyIcon = button.querySelector('.lucide-copy');
          const checkIcon = button.querySelector('.lucide-check');
          
          if (copyIcon && checkIcon) {
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            checkIcon.classList.add('animate-in', 'zoom-in', 'duration-300'); // Optional entry animation
            
            // Revert after 2 seconds
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              checkIcon.classList.add('hidden');
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });
    });
  });
</script>

<style is:global>
  /* Optional: Custom slim scrollbar for code blocks */
  .custom-scrollbar::-webkit-scrollbar {
    height: 8px;
    width: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #16161e; 
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #414868; 
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #565f89; 
  }
</style>
