---
import { getCollection } from "astro:content";
import createSlug from "@utils/createSlug";

const allProjects = await getCollection("project");
const homeProjects = allProjects
  .filter((project) => project.data.onHomePage)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

{
  homeProjects.length > 0 && (
    <div class="mt-8 mb-6">
      <div class="flex flex-row items-center gap-4 mb-6">
        <div class="p-2 bg-lime-400/10 rounded-md ring-1 ring-lime-400/20 text-lime-400">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-folder-git-2"
          >
            <>
              <path d="M9 20H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H20a2 2 0 0 1 2 2v5" />
              <circle cx="13" cy="12" r="2" />
              <path d="M18 19c-2.8 0-5-2.2-5-5v8" />
              <circle cx="20" cy="19" r="2" />
            </>
          </svg>
        </div>
        <h2 class="m-0! text-2xl font-extrabold text-white leading-none tracking-wider capitalize">
          Featured Projects
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {homeProjects.map((project) => (
          <div class="group relative flex flex-col justify-between bg-zinc-900/50 border border-zinc-800 hover:border-lime-400/50 rounded-xl p-5 transition-all duration-300 hover:bg-zinc-800/50 overflow-hidden">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-lime-400/10 blur-2xl rounded-full group-hover:bg-lime-400/20 transition-all duration-500" />

            <div class="relative z-10">
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-xl font-bold text-neutral-100 m-0 group-hover:text-lime-400 transition-colors">
                  <a
                    href={`/project/${createSlug(project.id)}`}
                    class="focus:outline-none"
                  >
                    <span class="absolute inset-0" aria-hidden="true" />
                    {project.data.title}
                  </a>
                </h3>
                {project.data.version && (
                  <span class="inline-flex items-center rounded-sm bg-zinc-800 px-2 py-0.5 text-xs font-mono font-medium text-zinc-400 ring-1 ring-inset ring-zinc-700/50">
                    v{project.data.version}
                  </span>
                )}
              </div>

              <p class="text-sm text-neutral-400 line-clamp-3 mb-4 font-sans leading-relaxed">
                {project.data.description}
              </p>
            </div>

            <div class="relative z-10 flex flex-wrap items-center gap-2 mt-auto">
              {project.data.tags.slice(0, 3).map((tag: string) => (
                <span class="inline-flex items-center rounded-full bg-zinc-800/80 px-2.5 py-0.5 text-[10px] font-medium text-zinc-300 tracking-wide uppercase">
                  {tag}
                </span>
              ))}
              {project.data.tags.length > 3 && (
                <span class="text-xs text-zinc-500 font-mono">
                  +{project.data.tags.length - 3}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}
