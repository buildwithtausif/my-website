---
    interface Props {
        bwshName?: string,
        bwshFalseText?: string
    }

    const {
        bwshName="bwsh 22.29-beta", 
        bwshFalseText=`Loading glance profiles took ${Math.floor(Math.random()*1000)}ms`
    } = Astro.props as Props;

---
<div class="codeBox w-[90%] md:w-145 bg-olive-900 min-h-14 font-mono text-lime-700 rounded-xs mx-auto p-2.5">
    {bwshName} <br/>
    {bwshFalseText} <br/><br/>
    <!-- if any heading is passed for the falseApplicaion -->
    <h2>
        <slot/>
    </h2>
</div>