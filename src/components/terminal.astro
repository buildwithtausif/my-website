---
interface Props {
  /** The mock terminal user name. Default: "tausif" */
  user?: string;
  /** The mock terminal host machine. Default: "forge" */
  host?: string;
  /** The mock current path displayed in the header. Default: "~/skills" */
  path?: string;
  /** The mock command being executed. Default: "fetch skills" */
  command?: string;
  /** Array of skill items to list as the output of the command. */
  data: {
    label: string;
    value: string;
  }[];
}

const {
  user = "tausif",
  host = "forge",
  path = "~/skills",
  command = "fetch skills",
  data = [],
} = Astro.props;
---

<div class="skills mb-10 w-full rounded-sm border border-zinc-800 bg-[#0a0a0a] font-mono shadow-xl relative">
  <!-- Retro Terminal Header -->
  <div class="flex items-center px-4 py-2 bg-zinc-900/80 border-b border-zinc-800">
    <div class="flex gap-2">
      <div class="w-3 h-3 rounded-full bg-zinc-700"></div>
      <div class="w-3 h-3 rounded-full bg-zinc-700"></div>
      <div class="w-3 h-3 rounded-full bg-zinc-700"></div>
    </div>
    <div class="mx-auto text-xs text-zinc-500 font-bold tracking-wider mr-10">
      {user}@{host}: {path}
    </div>
  </div>
  <!-- Terminal Body -->
  <div class="p-4 md:p-6 text-sm md:text-base text-zinc-300">
    <div class="mb-4">
      <span class="text-lime-400 font-bold">{user}@{host}</span><span class="text-zinc-500">:</span><span class="text-blue-400 font-bold">~</span><span class="text-zinc-500">$</span> {command}
    </div>

    <div class="pl-2 space-y-3">
      {
        data.map((item) => (
          <div class="flex flex-col sm:flex-row sm:items-start">
            <span class="text-lime-400 w-32 shrink-0 font-semibold">
              {item.label}
            </span>
            <span class="text-zinc-300">
              <span class="text-zinc-500 mr-2">»</span>
              {item.value}
            </span>
          </div>
        ))
      }
    </div>

    <div class="mt-6 flex items-center">
      <span class="text-lime-400 font-bold">{user}@{host}</span><span class="text-zinc-500">:</span><span class="text-blue-400 font-bold">~</span><span class="text-zinc-500">$</span>
      <span class="w-2.5 h-5 ml-2 mt-0.5 bg-lime-400 animate-pulse"></span>
    </div>
  </div>
</div>
