---
import { getCollection, type CollectionEntry } from "astro:content";
import createSlug from "@utils/createSlug";

const allBlogPosts = await getCollection("blog");
const allProjects = await getCollection("project");

let displayPosts: (CollectionEntry<"blog"> | CollectionEntry<"project">)[] =
  allBlogPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 2);

let isProject = false;
if (displayPosts.length === 0) {
  displayPosts = allProjects
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 1);
  isProject = true;
}
---

{
  displayPosts.length > 0 && (
    <>
      <h1 class="text-lg mb-4 text-lime-400 text-center">
        <span class="press-start-2p-regular">Latest Posts</span>
      </h1>
      <div class="flex flex-col gap-4 items-center">
        {displayPosts.map((post) => (
          <a
            href={`/${isProject ? "project" : "blog"}/${createSlug(post.id)}`}
            class="block no-underline"
          >
            <div
              class="card-board"
              data-topic={isProject ? post.data.description : post.data.title}
            >
              <div class="topic-name">
                {isProject ? post.data.description : post.data.title}
              </div>
            </div>
          </a>
        ))}
      </div>
    </>
  )
}
<style>
  .card-board {
    border: 2px solid oklch(84.1% 0.238 128.85);
    width: 320px;
    min-height: 64px;
    border-radius: 5px;
    border-right-width: 10px;
    border-left-width: 10px;
    color: white;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  @supports (corner-shape: scoop) {
    .card-board {
      corner-shape: scoop;
    }
  }
  .card-board::before {
    content: attr(data-topic);
    position: absolute;
    inset: 0;
    box-sizing: border-box;
    background-color: oklch(84.1% 0.238 128.85);
    color: black;
    padding: 8px;
    clip-path: inset(
      -1px -1px -1px 100%
    ); /* fully clipped (invisible) by default */
  }
  @keyframes growRight {
    from {
      clip-path: inset(-1px -1px -1px 100%);
    }
    10% {
      clip-path: inset(-1px -1px -1px 90%);
    }
    25% {
      clip-path: inset(-1px -1px -1px 65%);
    }
    55% {
      clip-path: inset(-1px -1px -1px 35%);
    }
    75% {
      clip-path: inset(-1px -1px -1px 15%);
    }
    to {
      clip-path: inset(-1px -1px -1px -1px);
    }
  }
  .card-board:hover::before {
    animation: growRight 170ms ease-in forwards;
  }
  .topic-name {
    width: 100%;
    padding: 8px;
    box-sizing: border-box;
  }
</style>
