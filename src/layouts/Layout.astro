---
import "../styles/global.css";
import { Image } from "astro:assets";
import Navigation from "@components/navigation.astro";
import Socials from "@components/socials.astro";
import Footer from "@components/footer.astro";
import dustin from "@res/images/dustin.jpg";
// metadata
interface Props {
  title: string;
  desc?: string;
  keywords?: string;
}

const {
  title = "Tausif Alam | Full Stack Developer",
  desc = "developing scalable systems for every business needs, I'm a full stack developer specializing in Node.js and Go (Programming Language) and related frameworks.",
  keywords = "Tausif Alam, Tausif Alam portfolio, full stack developer, Node.js developer, Golang developer, backend developer, web developer, system design, freelancer",
} = Astro.props as Props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={desc} />
    <meta name="keywords" content={keywords} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen scanline-bg">
    <Navigation />
    <!-- Twitter-style 2-column grid -->
    <div
      class="mx-auto flex flex-col lg:flex-row w-full max-w-[1265px] min-h-screen px-4 sm:px-6 lg:px-0 pb-24 lg:pb-0 pt-6 lg:pt-10"
    >
      <!-- Middle Column — main feed -->
      <main
        class="flex-1 min-w-0 lg:border-r lg:border-white/10 pb-6 lg:pb-0 lg:pr-8"
      >
        <slot name="no-bs-zone" />
        <slot name="how-it-started" />
      </main>

      <!-- Right Sidebar — stacks below on mobile, native sticky on lg+ -->
      <aside
        class="w-full border-t border-white/10 pt-6 lg:border-t-0 lg:pt-0 lg:w-[350px] lg:shrink-0 self-start lg:sticky lg:top-24 lg:pl-8 overflow-x-hidden mb-2"
      >
        <slot name="featuredWidget" />
        <!-- dustin's widget -->
        <div class="hidden lg:flex relative rounded-sm overflow-hidden isolate group mb-6 border border-zinc-800 shadow-xl m-2">
          <Image src={dustin} alt="Dustin Henderson Stranger Things" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500 -z-10" />
          <div class="absolute inset-0 bg-linear-to-t from-black via-black/70 to-transparent -z-10" />
          <div class="relative p-5 pt-40 w-full flex flex-col justify-end">
             <p class="font-mono text-[13px] leading-relaxed text-zinc-300 drop-shadow-md">
                Alright, so here’s the deal—you can navigate the entire site using these controls. It’s pretty straightforward… I made sure of that.<br/><br/>
                <span class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5">H</span>
                <span class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5">B</span>
                <span class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5">P</span>
                <span class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5">R</span>
             </p>
          </div>
        </div>
        <Socials />
        <Footer />
      </aside>
    </div>
  </body>
</html>
