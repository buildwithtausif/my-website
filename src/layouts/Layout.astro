---
import "../styles/global.css";
import "../styles/fontfamily.css";
import { Image } from "astro:assets";
import Navigation from "@components/navigation.astro";
import Socials from "@components/socials.astro";
import Footer from "@components/footer.astro";
import SmoothScrollIsland from "@components/SmoothScrollIsland";
import ScrollToBottom from "@components/ScrollToBottom.astro";
// images
import dustin from "@res/images/dustin.jpg";
import { getSEOForPath } from "@utils/seoConfig";

const seo = getSEOForPath(Astro.url.pathname);

// metadata
interface Props {
  title?: string;
  desc?: string;
  keywords?: string;
}

const {
  title = seo.title,
  desc = seo.desc,
  keywords = seo.keywords,
} = Astro.props as Props;
const pathname = Astro.url.pathname.replace(/\/$/, "");
const canonical = new URL(pathname || "/", Astro.site).toString();
---

<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-5J5KDXHK");
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="utf-8" />
    <title>{title}</title>
    <!-- basic metadata -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={desc} />
    <meta name="keywords" content={keywords} />
    <!-- open graph metadata -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={seo.image?.src} />
    <meta property="og:image:width" content={seo.image?.width.toString()} />
    <meta property="og:image:height" content={seo.image?.height.toString()} />
    <meta property="og:image:type" content={seo.image?.format} />
    <meta property="og:image:alt" content={title} />
    <!-- twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={seo.image?.src} />
    <meta name="twitter:image:width" content={seo.image?.width.toString()} />
    <meta name="twitter:image:height" content={seo.image?.height.toString()} />
    <meta name="twitter:image:type" content={seo.image?.format} />
    <meta name="twitter:image:alt" content={title} />
  </head>
  <body class="min-h-screen scanline-bg">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-5J5KDXHK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <Navigation />
    <!-- Twitter-style 2-column grid -->
    <div
      class="mx-auto flex flex-col lg:flex-row w-full max-w-[1265px] min-h-screen px-4 sm:px-6 lg:px-0 pb-24 lg:pb-0 pt-6 lg:pt-10"
    >
      <!-- Middle Column — main feed -->
      <main
        class="flex-1 min-w-0 lg:border-r lg:border-white/10 pb-6 lg:pb-0 lg:pr-8"
      >
        <slot name="no-bs-zone" />
      </main>

      <!-- Right Sidebar — stacks below on mobile, native sticky on lg+ -->
      <aside
        class="w-full border-t border-white/10 pt-6 lg:border-t-0 lg:pt-0 lg:w-[350px] lg:shrink-0 self-start lg:sticky lg:top-24 lg:pl-8 overflow-x-hidden mb-2"
      >
        <slot name="featuredWidget" />
        <!-- dustin's widget -->
        <div
          class="hidden lg:flex relative rounded-sm overflow-hidden isolate group mb-6 border border-zinc-800 shadow-xl m-2"
        >
          <Image
            src={dustin}
            alt="Dustin Henderson Stranger Things"
            class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500 -z-10"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-black via-black/70 to-transparent -z-10"
          >
          </div>
          <div class="relative p-5 pt-40 w-full flex flex-col justify-end">
            <p
              class="font-mono text-[13px] leading-relaxed text-zinc-300 drop-shadow-md"
            >
              Alright, so here’s the deal—you can navigate the entire site using
              these controls. It’s pretty straightforward… I made sure of that.<br
              /><br />
              <span
                class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5"
                >H</span
              >
              <span
                class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5"
                >B</span
              >
              <span
                class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5"
                >P</span
              >
              <span
                class="bg-lime-400 text-stone-900 px-2 py-0.5 font-bold rounded-[2px] mx-0.5"
                >R</span
              >
            </p>
          </div>
        </div>
        <Socials />
        <Footer />
      </aside>
    </div>
    <SmoothScrollIsland client:idle />
    <ScrollToBottom />
  </body>
</html>
