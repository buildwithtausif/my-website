---
import "../styles/global.css";
import Navigation from "@components/navigation.astro";
import { getSEOForPath } from "@utils/seoConfig";
import BaseLayout from "./baseLayour.astro";

const seo = getSEOForPath(Astro.url.pathname);

// metadata for seo
interface Props {
  title?: string;
  desc?: string;
  keywords?: string;
  image?: import("astro").ImageMetadata;
}
const {
  title = seo.title,
  desc = seo.desc,
  keywords = seo.keywords,
  image = seo.image,
} = Astro.props as Props;
// canonnical url for seo
const pathname = Astro.url.pathname.replace(/\/$/, "");
const canonical = new URL(pathname || "/", Astro.site).toString();
---

<html lang="en">
  <head>
    <BaseLayout url={Astro.url.origin} />
    <meta charset="utf-8" />
    <title>{title}</title>
    <!-- basic metadata -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={desc} />
    <meta name="keywords" content={keywords} />
    <!-- open graph metadata -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <!-- conditional og:image for project and blog pages -->
    <meta property="og:image" content={image?.src} />
    <meta property="og:image:width" content={image?.width.toString()} />
    <meta property="og:image:height" content={image?.height.toString()} />
    <meta property="og:image:type" content={image?.format} />
    <!-- twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={image?.src} />
    <meta name="twitter:image:width" content={image?.width.toString()} />
    <meta name="twitter:image:height" content={image?.height.toString()} />
    <meta name="twitter:image:type" content={image?.format} />
    <meta name="twitter:image:alt" content={title} />
  </head>
  <body class="scanline-bg">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-5J5KDXHK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <Navigation />
    <div class="content-wrapper w-full min-h-screen">
      <slot />
    </div>
  </body>
</html>
